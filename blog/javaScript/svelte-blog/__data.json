_TAG_END --\u003E\u003C\u002Fpre\u003E\n\u003Cp\u003Eslot에 스벨트 페이지들이 렌더되게 된다.\u003C\u002Fp\u003E\n\u003Cp\u003E스벨트킷은 넥스트와 비슷하게 routes에서 라우팅이 된다.\u003C\u002Fp\u003E\n\u003Chr\u003E\n\u003Ch3 id=\"데이터-가져오기\"\u003E\u003Ca aria-hidden=\"true\" tabindex=\"-1\" href=\"#데이터-가져오기\"\u003E\u003Cspan class=\"icon icon-link\"\u003E\u003C\u002Fspan\u003E\u003C\u002Fa\u003E데이터 가져오기\u003C\u002Fh3\u003E\n\u003Cp\u003Esrc\u002Froutes\u002F+page.svelte\u003C\u002Fp\u003E\n\u003Cpre class=\"language-js\"\u003E\u003C!-- HTML_TAG_START --\u003E\u003Ccode class=\"language-js\"\u003E\u003Cspan class=\"token operator\"\u003E&lt;\u003C\u002Fspan\u003Escript\u003Cspan class=\"token operator\"\u003E\u003E\u003C\u002Fspan\u003E\n\t\u003Cspan class=\"token keyword\"\u003Eimport\u003C\u002Fspan\u003E Pagination \u003Cspan class=\"token keyword\"\u003Efrom\u003C\u002Fspan\u003E \u003Cspan class=\"token string\"\u003E'$lib\u002Fcomponents\u002FPosts\u002FPagination.svelte'\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E;\u003C\u002Fspan\u003E\n\t\u003Cspan class=\"token keyword\"\u003Eimport\u003C\u002Fspan\u003E \u003Cspan class=\"token string\"\u003E'$lib\u002Fstyles\u002F_main.scss'\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E;\u003C\u002Fspan\u003E\n\t\u003Cspan class=\"token keyword\"\u003Eimport\u003C\u002Fspan\u003E PostList \u003Cspan class=\"token keyword\"\u003Efrom\u003C\u002Fspan\u003E \u003Cspan class=\"token string\"\u003E'$lib\u002Fcomponents\u002FPosts\u002FPostList.svelte'\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E;\u003C\u002Fspan\u003E\n\t\u003Cspan class=\"token keyword\"\u003Eimport\u003C\u002Fspan\u003E Category \u003Cspan class=\"token keyword\"\u003Efrom\u003C\u002Fspan\u003E \u003Cspan class=\"token string\"\u003E'$lib\u002Fcomponents\u002FPosts\u002FCategory.svelte'\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E;\u003C\u002Fspan\u003E\n\t\u003Cspan class=\"token keyword\"\u003Eimport\u003C\u0